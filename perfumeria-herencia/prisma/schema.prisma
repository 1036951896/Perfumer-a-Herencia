// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Marca {
  id          String   @id @default(uuid())
  nombre      String   @unique
  descripcion String?
  paisOrigen  String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  productos Producto[]

  @@map("marcas")
}

model Categoria {
  id          String         @id @default(uuid())
  nombre      String         @unique
  descripcion String?
  activa      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  productos Producto[]

  @@map("categorias")
}

model Coleccion {
  id             String     @id @default(uuid())
  nombre         String
  slug           String     @unique
  descripcion    String?
  seoTitle       String?
  seoDescription String?
  imagenUrl      String?    // imagen card carrusel
  bannerUrl      String?    // hero de página colección
  colorTexto     String?    @default("#1a1a1a") // color del texto en el carrusel
  orden          Int        @default(0)
  activo         Boolean    @default(true)
  destacado      Boolean    @default(false)
  segmento       Segmento
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  productos Producto[]

  @@index([segmento])
  @@index([activo])
  @@map("colecciones")
}

model Producto {
  id            String        @id @default(uuid())
  nombre        String
  descripcion   String?
  segmento      Segmento      // ORIGINAL o REPLICA
  genero        Genero
  concentracion Concentracion
  volumen       String        // "100ml", "50ml", etc.
  marcaId       String
  marca         Marca         @relation(fields: [marcaId], references: [id], onDelete: Cascade)
  categoriaId   String
  categoria     Categoria     @relation(fields: [categoriaId], references: [id])
  precio        Float
  stock         Int           @default(0)
  imagenUrl     String
  destacado     Boolean       @default(false)
  activo        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  pedidoItems PedidoItem[]
  colecciones Coleccion[]

  @@index([marcaId])
  @@index([categoriaId])
  @@index([segmento])
  @@index([genero])
  @@map("productos")
}

model Pedido {
  id             String        @id @default(uuid())
  referencia     String        @unique
  nombreCliente  String?
  emailCliente   String?
  telefonoCliente String?
  direccion      String?
  total          Float
  estado         EstadoPedido  @default(PENDIENTE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  items PedidoItem[]

  @@map("pedidos")
}

model PedidoItem {
  id        String   @id @default(uuid())
  pedidoId  String
  pedido    Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  productoId String
  producto  Producto @relation(fields: [productoId], references: [id])
  cantidad  Int
  precio    Float

  @@index([pedidoId])
  @@index([productoId])
  @@map("pedido_items")
}

model AdminUser {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // bcrypt hashed
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_users")
}

model ConfigPasarela {
  id            String   @id @default(uuid())
  proveedor     String   @unique   // "mercadopago" | "addi"
  activo        Boolean  @default(false)
  // Mercado Pago
  mpPublicKey   String?
  mpAccessToken String?
  // Addi
  addiAlias     String?
  addiApiKey    String?
  // Nombre visible y notas internas
  nombreVisible String?
  notas         String?
  updatedAt     DateTime @updatedAt

  @@map("config_pasarelas")
}

enum Segmento {
  ORIGINAL
  REPLICA
}

enum Genero {
  MASCULINO
  FEMENINO
  UNISEX
}

enum Concentracion {
  EAU_DE_PARFUM
  EAU_DE_TOILETTE
  EXTRAIT
  EAU_DE_COLOGNE
}

enum EstadoPedido {
  PENDIENTE
  EN_PROCESO
  ENVIADO
  ENTREGADO
  CANCELADO
}

model AdminConfig {
  id           String @id @default("admin")
  passwordHash String

  @@map("admin_config")
}
